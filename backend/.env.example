# Asterion AI Backend Configuration
# Copy this file to .env and adjust values as needed.

# API server
ASTERION_API_HOST=127.0.0.1
ASTERION_API_PORT=8000

# Ollama (local model runtime)
OLLAMA_BASE_URL=http://127.0.0.1:11434
ASTERION_DEFAULT_MODEL=llama3.2
ASTERION_MAX_TOKENS=2048
ASTERION_CHAT_HISTORY_LIMIT=20

# Encryption key storage
ASTERION_KEYRING_SERVICE=asterion-ai
ASTERION_KEYRING_DB_KEY_NAME=sqlcipher-main

# External services
ASTERION_COMFYUI_URL=http://127.0.0.1:8188
ASTERION_SEARXNG_URL=http://127.0.0.1:8080

# Data directory (default: ~/.asterion)
# ASTERION_DATA_DIR=/path/to/data

# Development only: allow unencrypted SQLite (DO NOT use in production)
# ASTERION_ALLOW_PLAINTEXT_SQLITE_FOR_DEV=1
