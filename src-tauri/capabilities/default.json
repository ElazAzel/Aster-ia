{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default Asterion AI desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/asterion-backend",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            "8000"
          ]
        }
      ]
    }
  ]
}
