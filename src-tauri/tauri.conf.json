{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Asterion AI",
  "version": "0.1.0",
  "identifier": "ai.asterion.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Asterion AI",
        "width": 1350,
        "height": 973,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Asterion AI Loading...",
        "width": 400,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "center": true,
        "url": "index.html?splash=true"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000 http://127.0.0.1:11434 http://localhost:11434; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/asterion-backend"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/ElazAzel/Aster-ia/main/updater.json"
      ],
      "pubkey": "dW51c2VkX3B1YmxpY19rZXlfZm9yX2RlbW9uc3RyYXRpb25fcHVycG9zZXNfCg=="
    }
  }
}
